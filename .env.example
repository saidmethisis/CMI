# Канонический адрес сайта (для sitemap/RSS/OG/llms.txt). В проде укажите ваш домен.
SITE_URL=https://asosiyaktiv.uz

# База данных (SQLite по умолчанию — файл, без сервера).
# Для продакшена замените на PostgreSQL: postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"

# Скопируйте в .env.local и заполните, чтобы включить реальную AI-генерацию.
# Без ключа AI Wizard работает на встроенном мок-генераторе (демо не ломается).
OPENAI_API_KEY=
# необязательно — модель по умолчанию gpt-4o
OPENAI_MODEL=gpt-4o

# Секрет для подписи серверных токенов (сессии/HMAC). В ПРОДЕ обязателен —
# задайте длинную случайную строку, иначе используется небезопасный дефолт.
AUTH_SECRET=

# Google reCAPTCHA v2 («Я не робот»). Получить на https://www.google.com/recaptcha/admin
# (тип: reCAPTCHA v2 → «I'm not a robot»). Без реальных ключей капча декоративна.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Отправка писем (сброс пароля, подтверждение email). Ключ с resend.com.
# Без ключа письма пишутся в серверный лог (dev), поток не ломается.
RESEND_API_KEY=
EMAIL_FROM="Asosiy Aktiv <noreply@yourdomain.uz>"

# ── SEO / верификация в поисковиках ──────────────────────────────────────────
# Google Search Console → «HTML-тег» → скопировать content
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Яндекс.Вебмастер → «Мета-тег» → скопировать content
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ── Аналитика (подключается только если задан ID) ────────────────────────────
NEXT_PUBLIC_GA_ID=          # Google Analytics 4, вид G-XXXXXXX
NEXT_PUBLIC_GTM_ID=         # Google Tag Manager, вид GTM-XXXXXX
NEXT_PUBLIC_YM_ID=          # Яндекс.Метрика, числовой номер счётчика

# ── Реклама: authorized sellers (ads.txt) ────────────────────────────────────
# Напр. AdSense: "google.com, pub-0000000000000000, DIRECT, f08c47fec0942fa0"
# Несколько строк через \n
ADS_TXT=

# ── Реквизиты организации (правовые страницы / выходные данные / согласие ПД) ─
# Заполните реальными данными и проверьте у юриста перед публикацией (нормы РУз).
NEXT_PUBLIC_ORG_NAME="Asosiy Aktiv"
NEXT_PUBLIC_ORG_FOUNDER=      # учредитель (юрлицо/ФИО)
NEXT_PUBLIC_ORG_EDITOR=       # главный редактор (ФИО)
NEXT_PUBLIC_ORG_EMAIL=        # контактный e-mail
NEXT_PUBLIC_ORG_PHONE=        # контактный телефон
NEXT_PUBLIC_ORG_ADDRESS=      # юридический адрес в РУз
NEXT_PUBLIC_ORG_SMI_CERT=     # № и дата свидетельства о регистрации СМИ (при наличии)
NEXT_PUBLIC_ORG_PD_REGISTRY=  # № в Госреестре баз персональных данных
NEXT_PUBLIC_ORG_AGE=18+       # возрастная маркировка (0+/6+/12+/16+/18+)
